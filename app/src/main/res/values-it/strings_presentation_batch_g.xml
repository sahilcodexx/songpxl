    <string name="presentation_batch_g_beta_sheet_welcome_title">Benvenuto in PlayPix 0.6.0-beta</string>
    <string name="presentation_batch_g_beta_sheet_welcome_body">Questa beta è ora focalizzata su stabilità, prestazioni e riproduzione cross-dispositivo, con nuove integrazioni importanti.</string>
