    <string name="presentation_batch_g_beta_sheet_welcome_body">This beta is now focused on stability, performance, and cross-device playback while shipping major new integrations.</string>
    <string name="presentation_batch_g_beta_sheet_expect_title">What to expect</string>
    <string name="presentation_batch_g_beta_sheet_expect_1">Faster daily use: smoother startup, navigation, and player interactions across the app.</string>
    <string name="presentation_batch_g_beta_sheet_expect_2">Broader device support: Android Auto, Wear OS upgrades, and stronger Cast reliability.</string>
    <string name="presentation_batch_g_beta_sheet_expect_3">Expanded cloud ecosystem: Telegram playlists, NetEase sync, QQ Music, and Google Drive streaming updates.</string>
    <string name="presentation_batch_g_beta_sheet_expect_4">Large reliability pass: queue/shuffle logic, background playback behavior, and many UI fixes.</string>
