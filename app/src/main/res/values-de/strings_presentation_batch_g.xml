    <string-array name="presentation_batch_g_changelog_060_whats_new">
        <item>Android Auto für die Wiedergabe im Auto ist jetzt verfügbar.</item>
        <item>Wear OS-Unterstützung ist live, inklusive besserer Watch-to-Phone-Steuerung.</item>
        <item>Cloud-Integrationen erweitert: Telegram, NetEase, QQ Music und Google Drive verbessert.</item>
        <item>Zuletzt gespielt und persistente Queue-Wiederherstellung halten deine Session bereit.</item>
        <item>Backup &amp; Wiederherstellen v3 und Account-Verwaltung sind jetzt dabei.</item>
        <item>Lyrics verbessert: manuelle Suchfallback und bessere Speicherung.</item>
    </string-array>
    <string-array name="presentation_batch_g_changelog_060_improvements">
        <item>Großer Performance-Pass über Start, Bibliothek, Queue und Player.</item>
        <item>Player, Cast, Lyrics, Künstler und Genre wurden für flüssigere Nutzung überarbeitet.</item>
        <item>Navigation und Suche zuverlässiger, mit sichererem Routing.</item>
        <item>Audio-Wiedergabe-Kompatibilität für mehr Geräte und Formate verbessert.</item>
        <item>Mehrfachauswahl für Songs, Alben und Playlists erweitert.</item>
    </string-array>
    <string-array name="presentation_batch_g_changelog_060_fixes">
        <item>Queue und Shuffle-Verhalten jetzt stabiler und vorhersehbarer.</item>
        <item>Mehrere Hintergrundwiedergabe- und Cast-Randfälle behoben.</item>
        <item>Sleep Timer, Ordner-Navigation und Album-Artist-Absturz behoben.</item>
        <item>Widget-Laden und Service-Stabilität verbessert.</item>
        <item>Allgemeine Bug-Fixes und UI-Politur.</item>
    </string-array>
    <string-array name="presentation_batch_g_changelog_050_highlights">
        <item>Material 3 Expressiv UI-Update</item>
        <item>10-Band-Equalizer &amp; Effekte</item>
        <item>Neuer Bibliotheks-Sync-Flow</item>
        <item>KI-Integration (Gemini-Modelle)</item>
        <item>M3U-Playlist-Import/Export</item>
        <item>Deezer-Künstlerbild-Integration</item>
        <item>Eigene Playlist-Cover</item>
    </string-array>
    <string-array name="presentation_batch_g_changelog_050_improvements">
        <item>Settings-Architektur überarbeitet</item>
        <item>Queue &amp; Player-Animationen</item>
        <item>Baseline-Profile &amp; Performance</item>
        <item>Besseres Lyrics-System mit Sync-Offset</item>
    </string-array>
    <string-array name="presentation_batch_g_changelog_050_fixes">
        <item>Cast-Stabilität verbessert</item>
        <item>Player-Sheet-Stabilität</item>
        <item>Allgemeine Bug-Fixes &amp; Aufräumen</item>
    </string-array>
    <string-array name="presentation_batch_g_changelog_040_highlights">
        <item>Großes Navigationsredesign</item>
        <item>Neuer Dateiexplorer zur Auswahl von Quellverzeichnissen</item>
        <item>Neue Konnektivitäts- und Cast-Funktionen</item>
        <item>Nahtlose Kontinuität zwischen Remote-Geräten</item>
        <item>Lückenloser Übergang zwischen Songs</item>
        <item>Crossfade-Steuerung</item>
        <item>Neue eigene Übergänge (nur für Playlists)</item>
        <item>Nach App-Schließung weiterspielen</item>
        <item>UI-Optimierungen</item>
        <item>Verbesserte Statistiken</item>
        <item>Neu gestaltete Queue-Steuerung mit mehr Funktionen</item>
        <item>Verbesserte Unterstützung verschiedener Dateitypen</item>
        <item>Verbesserter Berechtigungs-Controller</item>
        <item>Kleinere Bug-Fixes</item>
    </string-array>
    <string-array name="presentation_batch_g_changelog_030_whats_new">
        <item>Reichhaltigerer Hörstatistik-Hub mit tieferen Einblicken eingeführt.</item>
        <item>Schwebender Quick-Player zum sofortigen Öffnen und Vorschauen lokaler Dateien.</item>
        <item>Ordner-Tab mit Baum-Navigator und Playlist-Ansicht hinzugefügt.</item>
    </string-array>
    <string-array name="presentation_batch_g_changelog_030_improvements">
        <item>Gesamte Material 3 Expressiv-Oberfläche verfeinert.</item>
        <item>Metadaten-Bearbeitung unterstützt jetzt Cover-Änderungen.</item>
        <item>Animationen und Übergänge flüssiger.</item>
        <item>Künstler-Bildschirm mit reichhaltigeren Details überarbeitet.</item>
        <item>DailyMix und dein Mix mit klügeren, vielfältigeren Auswahlen verbessert.</item>
        <item>KI-Playlist-Generierung gestärkt.</item>
        <item>Suchrelevanz und -präsentation verbessert.</item>
        <item>Unterstützung für mehr Audioformate erweitert.</item>
    </string-array>
    <string-array name="presentation_batch_g_changelog_030_fixes">
        <item>Metadaten-Probleme behoben, Song-Details bleiben überall korrekt.</item>
        <item>Benachrichtigungsverknüpfungen funktionieren wieder zuverlässig.</item>
    </string-array>
    <string-array name="presentation_batch_g_changelog_020_added">
        <item>Chromecast-Unterstützung für das Übertragen von Audio.</item>
        <item>In-App-Changelog für aktuelle Infos.</item>
        <item>Unterstützung für .LRC-Dateien, eingebettet und extern.</item>
        <item>Offline-Lyrics-Unterstützung.</item>
        <item>Synchronisierte Lyrics (mit Song abgestimmt).</item>
        <item>Neuer Bildschirm für die vollständige Queue.</item>
        <item>Songs in der Queue neu sortieren und entfernen.</item>
        <item>Mini-Player-Gesten (nach unten wischen zum Schließen).</item>
        <item>Weitere Material-Animationen.</item>
        <item>Neue Einstellungen zur Anpassung von Look &amp; Feel.</item>
        <item>Neue Einstellungen zum Cache leeren.</item>
    </string-array>
    <string-array name="presentation_batch_g_changelog_020_changed">
        <item>Vollständiges Redesign der Benutzeroberfläche.</item>
